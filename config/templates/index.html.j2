<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Frontend Web Tier</title>
  <style>
    body { font-family: 'Segoe UI', sans-serif; background: #1a1a2e; color: #eaeaea; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
    .card { background: #16213e; border: 1px solid #0f3460; border-radius: 12px; padding: 2rem 3rem; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,0.4); }
    h1 { color: #e94560; margin-bottom: 0.5rem; }
    .hostname { font-size: 1.4rem; color: #53d8fb; }
    .tier { color: #8a8a8a; font-size: 0.9rem; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Frontend Web Tier</h1>
    <p class="hostname">Hostname: <strong>{{ ansible_hostname }}</strong></p>
    <p class="tier">Layer: VMSS Frontend &mdash; served by Nginx</p>
  </div>
</body>
</html>
